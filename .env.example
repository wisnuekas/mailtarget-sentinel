APP_PORT=8080
PUBLIC_BASE_URL=http://localhost:8080
# Set to 0 or omit for full super-user (all companies); set to e.g. 287 for scoped testing
COMPANY_ID=0

# Shared PostgreSQL from dashboard-api-service (required)
POSTGRES_DSN=postgres://user:pass@localhost:5432/dashboard?sslmode=disable

SQLITE_PATH=./data/sentinel.db
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

CLICKHOUSE_HOST=localhost:9000
CLICKHOUSE_HTTP=http://localhost:8123
CLICKHOUSE_DATABASE=default
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

MAILTARGET_API_KEY=your-api-key
MAILTARGET_TRANSMISSION_URL=https://transmission.mailtarget.co/v1
# MAILTARGET_APICONFIG_URL is no longer used for reads/writes (kept for reference only)
MAILTARGET_APICONFIG_URL=https://apiconfig.mailtarget.co/v1

ALERT_FROM_EMAIL=alerts@yourdomain.com
ALERT_FROM_NAME=Mailtarget Sentinel
ALERT_TO_EMAIL=ops@yourdomain.com
ALERT_TO_NAME=Ops Team
# CC on anomaly alert emails (To = company owner). Also used as To fallback when owner lookup fails.

KILL_SWITCH_HMAC_SECRET=change-me-in-production
SENTINEL_ADMIN_TOKEN=dev-sentinel-secret-2026

# Dashboard login (POST /auth/login)
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=s3ntinelg0d

# Dashboard (web/.env) — optional fallback if not using login session token:
# VITE_SENTINEL_ADMIN_TOKEN=dev-sentinel-secret-2026
