# VM deployment — copy to .env on the server and fill in secrets.
# PostgreSQL & ClickHouse run on separate hosts (not in docker-compose).

APP_PORT=8080
# Public URL reachable from ops email (kill-switch links)
PUBLIC_BASE_URL=http://<vm-host>:8080
COMPANY_ID=0

POSTGRES_DSN=postgres://USER:PASS@10.10.0.156:5432/mtarget-smtp?sslmode=disable

CLICKHOUSE_HOST=10.10.0.157:9000
CLICKHOUSE_HTTP=http://10.10.0.157:8123
CLICKHOUSE_DATABASE=default
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=

REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

SQLITE_PATH=/app/data/sentinel.db
CORS_ORIGINS=http://<vm-host>:5173,http://<vm-host>:8080

MAILTARGET_API_KEY=your-api-key
MAILTARGET_TRANSMISSION_URL=https://transmission.mailtarget.co/v1

ALERT_FROM_EMAIL=alerts@yourdomain.com
ALERT_FROM_NAME=Mailtarget Sentinel
ALERT_TO_EMAIL=ops@yourdomain.com
ALERT_TO_NAME=Ops Team

KILL_SWITCH_HMAC_SECRET=change-me-in-production
SENTINEL_ADMIN_TOKEN=change-me-in-production

DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-me-in-production

# Optional — pin image tag from registry
# SENTINEL_TAG=v1.0.0
